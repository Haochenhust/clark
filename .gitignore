node_modules/

# secrets & local config
.env

# runtime store: sqlite db, pid file, session transcripts, lark-cli config
# (contains the Feishu APP SECRET), and tmux scratch — NEVER commit any of it.
store/

# Runtime workspace: the bot uses workspace/ as its cwd and writes uploads, logs,
# and arbitrary scratch files there. Ignore everything EXCEPT the tracked template
# — persona (CLAUDE.md), Claude config + skills (.claude/), and MCP config.
workspace/*
!workspace/CLAUDE.md
!workspace/.claude/
!workspace/.mcp.json

*.log
.DS_Store
