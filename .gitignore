node_modules/

# secrets & local config
.env

# runtime store: sqlite db, pid file, session transcripts, lark-cli config
# (contains the Feishu APP SECRET), and tmux scratch — NEVER commit any of it.
store/

# Runtime workspace: the bot uses workspace/ as its cwd and writes uploads, logs,
# and arbitrary scratch files there. Ignore everything EXCEPT the tracked bot
# framework — persona (CLAUDE.md + soul.md), memory + rules, Claude config +
# skills (.claude/), and MCP config.
#
# NOTE: memory/ ships with generic templates, but the bot fills it with the
# user's personal data at runtime. Review (or scrub) memory/ before pushing to a
# public remote.
workspace/*
!workspace/CLAUDE.md
!workspace/soul.md
!workspace/memory/
!workspace/rules/
!workspace/.claude/
!workspace/.mcp.json

*.log
.DS_Store
