# --- Feishu / Lark bot credentials ---
# Create a custom app (bot) at https://open.feishu.cn (or https://www.larksuite.com)
# and enable long-connection / event subscription for im.message.receive_v1.
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat to send the boot/restart notification to (open_id or chat_id). Optional.
NOTIFY_CHAT_ID=

# The single workspace Claude runs in — the cwd for every chat's tmux session.
WORKSPACE_DIR=./workspace

# Optional: lark-cli config dir, exported into the agent env so workspace skills
# can call the Feishu API via lark-cli.
LARKSUITE_CLI_CONFIG_DIR=

# Log level: trace | debug | info | warn | error  (default: info)
# CLARK_LOG_LEVEL=info

# --- IMPORTANT: there is deliberately NO ANTHROPIC_API_KEY here ---
# clark drives the *interactive* `claude` CLI inside tmux, which uses your
# logged-in Claude Code subscription. Setting ANTHROPIC_API_KEY would force
# per-API-token billing — exactly what this project exists to avoid.
# Just run `claude` once and sign in before starting clark.
